{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hookahguide/schema/glossary-term.schema.json",
  "title": "GlossaryTerm",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["term", "category", "definition"],
    "additionalProperties": false,
    "properties": {
      "term": { "type": "string" },
      "category": { "type": "string", "enum": ["табак", "оборудование", "чаши", "забивка", "процесс", "угли"] },
      "definition": { "type": "string" },
      "articleRef": { "type": "string" }
    }
  }
}
