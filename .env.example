# Скопируйте в .env и задайте свои значения: cp .env.example .env

# Домен, на который указывает A-запись DNS вашего сервера.
# Caddy автоматически получит для него HTTPS-сертификат.
# Для локальной проверки можно поставить localhost (будет самоподписанный сертификат).
DOMAIN=api.example.ru

# Email для уведомлений Let's Encrypt (необязательно, но рекомендуется).
ACME_EMAIL=you@example.ru

# Мастер-ключ Meilisearch (минимум 16 байт). Сгенерировать: openssl rand -base64 32
MEILI_MASTER_KEY=ЗАМЕНИТЕ_НА_СЛУЧАЙНЫЙ_КЛЮЧ_МИН_16_БАЙТ

# Пароль PostgreSQL (любая случайная строка). Сгенерировать: openssl rand -base64 24
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_СЛУЧАЙНЫЙ_ПАРОЛЬ

# Секрет для подписи JWT (длинная случайная строка). Сгенерировать: openssl rand -base64 48
# ВАЖНО: смена секрета инвалидирует все выданные токены (юзеры разлогинятся).
JWT_SECRET=ЗАМЕНИТЕ_НА_ДЛИННЫЙ_СЛУЧАЙНЫЙ_СЕКРЕТ
